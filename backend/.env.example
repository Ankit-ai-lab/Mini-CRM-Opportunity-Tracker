NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mini-crm?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=2h

# Comma-separated list of allowed origins for CORS (your deployed frontend URL)
CLIENT_ORIGIN=http://localhost:5173
